# Copy to .env and fill in. All vars are optional except ANTHROPIC_API_KEY
# (required for the segment + label stages).

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
CLIPPER_LLM_MODEL=claude-sonnet-4-6
CLIPPER_LLM_MAX_TOKENS=8000
CLIPPER_LLM_EFFORT=low                  # low | medium | high | xhigh | max
CLIPPER_LLM_CONCURRENCY=8               # parallel label/segment LLM calls

# --- storage ---
CLIPPER_STORAGE_BACKEND=local
CLIPPER_STORAGE_ROOT=storage

# --- database ---
CLIPPER_DATABASE_URL=sqlite:///clipper.db

# --- ASR (transcription) ---
CLIPPER_ASR_BACKEND=faster_whisper      # faster_whisper | groq | openai
CLIPPER_ASR_MODEL=small                 # tiny|base|small|medium|large-v3 (small = cpu-friendly)
CLIPPER_ASR_DEVICE=cpu                  # cpu | cuda
CLIPPER_ASR_COMPUTE_TYPE=int8           # int8 (cpu) | float16 (gpu)
# CLIPPER_ASR_LANGUAGE=en               # unset = autodetect
# Groq cloud transcription (set CLIPPER_ASR_BACKEND=groq):
# GROQ_API_KEY=gsk_...
CLIPPER_GROQ_MODEL=whisper-large-v3-turbo   # or whisper-large-v3 / distil-whisper-large-v3-en

# --- segmentation ---
CLIPPER_SEGMENT_CHUNK_SIZE=120
CLIPPER_SEGMENT_CHUNK_OVERLAP=15

# --- boundaries ---
CLIPPER_PAD_LEAD_IN=0.25
CLIPPER_PAD_TAIL=0.35
CLIPPER_TARGET_MIN_SEC=15
CLIPPER_TARGET_MAX_SEC=90
CLIPPER_DROP_BELOW_SEC=8
CLIPPER_SENTENCE_GAP_SEC=0.6
CLIPPER_SNAP_WINDOW_SEC=0.8
CLIPPER_DEDUP_OVERLAP=0.5

# --- render ---
CLIPPER_VERTICAL=false                  # true = 9:16 reformat
CLIPPER_BURN_CAPTIONS=true
CLIPPER_VIDEO_CRF=20
CLIPPER_VIDEO_PRESET=veryfast
CLIPPER_YT_MAX_HEIGHT=1080

# --- ops ---
# CLIPPER_SKIP_BINARY_CHECK=1           # bypass ffmpeg/yt-dlp check (tests)
